{
  "name": "yunying-zhushou",
  "version": "1.0.8",
  "description": "资海云运营助手，用于多平台自动化运营管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win:dev": "node build-scripts/set-env.js dev && electron-builder --win",
    "build:win:prod": "node build-scripts/set-env.js prod && electron-builder --win",
    "build:win:dev:portable": "node build-scripts/set-env.js dev && electron-builder --win portable --ia32",
    "build:win:prod:portable": "node build-scripts/set-env.js prod && electron-builder --win portable --ia32",
    "release:win:dev": "node build-scripts/set-env.js dev && electron-builder --win --publish always",
    "release:win:prod": "node build-scripts/set-env.js prod && electron-builder --win --publish always",
    "build:dev": "npm run build:win:dev",
    "build:prod": "npm run build:win:prod",
    "build:dev:portable": "npm run build:win:dev:portable",
    "build:prod:portable": "npm run build:win:prod:portable",
    "build": "npm run build:win:prod",
    "build:dir": "electron-builder --win --dir",
    "build:portable": "npm run build:win:prod:portable",
    "build:mac:dev": "node build-scripts/set-env.js dev && electron-builder --mac --publish never",
    "build:mac:prod": "node build-scripts/set-env.js prod && electron-builder --mac --publish never",
    "build:mac": "npm run build:mac:prod",
    "release:mac:dev": "node build-scripts/set-env.js dev && electron-builder --mac --publish always",
    "release:mac:prod": "node build-scripts/set-env.js prod && electron-builder --mac --publish always",
    "release:mac": "npm run release:mac:prod",
    "release:win": "npm run release:win:prod"
  },
  "build": {
    "appId": "com.zhcloud.browser",
    "productName": "资海云运营助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "asarUnpack": [
      "injected-scripts/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "sherllyzhao",
        "repo": "browser",
        "releaseType": "release"
      }
    ],
    "win": {
      "icon": "icon.ico",
      "artifactName": "资海云运营助手-安装版-${version}-${arch}.${ext}",
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "资海云运营助手-便携版-${version}.exe",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "资海云运营助手",
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "资海云运营助手-mac-${version}-${arch}.${ext}",
      "icon": "icon.png",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "ZhCloud-Browser ${version}",
      "backgroundColor": "#ffffff",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^21.4.4",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.2.0"
  }
}
