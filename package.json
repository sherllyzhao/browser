{
  "name": "yunying-zhushou",
  "version": "1.2.0",
  "description": "资海云运营助手，用于多平台自动化运营管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --remote-debugging-port=9222",
    "sync-features": "node build-scripts/sync-features-version.js",
    "build:dev": "npm run sync-features && node build-scripts/set-env.js dev && electron-builder --win nsis --ia32",
    "build:prod": "npm run sync-features && node build-scripts/set-env.js prod && electron-builder --win nsis --ia32",
    "build:dev:portable": "npm run sync-features && node build-scripts/set-env.js dev && electron-builder --win portable --ia32",
    "build:prod:portable": "npm run sync-features && node build-scripts/set-env.js prod && electron-builder --win portable --ia32",
    "build": "npm run build:prod",
    "build:dir": "electron-builder --win --dir",
    "build:portable": "npm run build:prod:portable"
  },
  "build": {
    "appId": "com.zhcloud.browser",
    "productName": "资海云运营助手",
    "directories": {
      "output": "dist"
    },
    "electronVersion": "21.4.4",
    "files": [
      "main.js",
      "preload.js",
      "content-preload.js",
      "renderer.js",
      "script-manager.js",
      "domain-config.js",
      "index.html",
      "login.html",
      "not-auth.html",
      "not-available.html",
      "not-purchase.html",
      "publish-loading.html",
      "icon.ico",
      "icon.png",
      "logo1.png",
      "package.json",
      "injected-scripts/**",
      "assets/**"
    ],
    "asarUnpack": [
      "injected-scripts/**",
      "icon.ico",
      "icon.png",
      "logo1.png"
    ],
    "afterPack": "./build-scripts/afterPack.js",
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "资海云运营助手-便携版-safe-${version}.exe",
      "requestExecutionLevel": "user",
      "unpackDirName": "zhcloud-ops-assistant-portable-${version}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": false,
      "runAfterFinish": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "shortcutName": "资海云运营助手",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "21.4.4",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  }
}
