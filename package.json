{
  "name": "yunying-zhushou",
  "version": "1.0.5",
  "description": "资海云运营助手，用于多平台自动化运营管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:dev": "cross-env BUILD_ENV=dev electron-builder --win",
    "build:prod": "cross-env BUILD_ENV=prod electron-builder --win",
    "build:dev:portable": "cross-env BUILD_ENV=dev electron-builder --win portable --ia32",
    "build:prod:portable": "cross-env BUILD_ENV=prod electron-builder --win portable --ia32",
    "build": "npm run build:prod",
    "build:dir": "electron-builder --win --dir",
    "build:portable": "npm run build:prod:portable"
  },
  "build": {
    "appId": "com.zhcloud.browser",
    "productName": "资海云运营助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**"
    ],
    "asarUnpack": [
      "injected-scripts/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "资海云运营助手",
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^21.4.4",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  }
}
