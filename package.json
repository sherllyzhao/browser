{
  "name": "yunying-zhushou",
  "version": "1.0.9",
  "description": "资海云运营助手，用于多平台自动化运营管理",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:dev": "node build-scripts/set-env.js dev && electron-builder --win",
    "build:prod": "node build-scripts/set-env.js prod && electron-builder --win",
    "build:dev:portable": "node build-scripts/set-env.js dev && electron-builder --win portable --ia32",
    "build:prod:portable": "node build-scripts/set-env.js prod && electron-builder --win portable --ia32",
    "build": "npm run build:prod",
    "build:dir": "electron-builder --win --dir",
    "build:portable": "npm run build:prod:portable"
  },
  "build": {
    "appId": "com.zhcloud.browser",
    "productName": "资海云运营助手",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "content-preload.js",
      "renderer.js",
      "script-manager.js",
      "domain-config.js",
      "index.html",
      "login.html",
      "not-auth.html",
      "not-available.html",
      "not-purchase.html",
      "icon.ico",
      "icon.png",
      "logo1.png",
      "package.json",
      "injected-scripts/**",
      "assets/**"
    ],
    "asarUnpack": [
      "injected-scripts/**"
    ],
    "afterPack": "./build-scripts/afterPack.js",
    "win": {
      "icon": "icon.ico",
      "signAndEditExecutable": true,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "ia32"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "资海云运营助手-便携版-${version}.exe",
      "requestExecutionLevel": "user"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "资海云运营助手",
      "deleteAppDataOnUninstall": true,
      "include": "installer.nsh"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^21.4.4",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  }
}
